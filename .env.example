# ════════════════════════════════════════════════════════════════════════════
# ResolveAI — Environment Variables
# Copy this file to .env and fill in your own values.
# .env is gitignored and must NEVER be committed.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# ── LLM provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── Agent behaviour ───────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=1024
AGENT_TEMPERATURE=0.1
AGENT_MEMORY_WINDOW=20
AGENT_PROMPT_VERSION=v1
AGENT_RETRIEVAL_TOP_K=5
AGENT_LOW_CONFIDENCE_THRESHOLD=0.4

# ── Vector store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=insurance_kb

# ── Mock CRM ─────────────────────────────────────────────────────────────────
MOCK_CRM_URL=http://localhost:8002
MOCK_CRM_API_KEY=mock-crm-secret-key

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=resolveai
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=changeme-in-prod
DATABASE_URL=postgresql://resolveai:changeme-in-prod@localhost:5433/resolveai

# ── Integrations ─────────────────────────────────────────────────────────────
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_ESCALATION_CHANNEL=#support-escalations
GOOGLE_CREDENTIALS_FILE=credentials/google_credentials.json
GOOGLE_CALENDAR_ID=primary

# ── Voice ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=http://localhost:8000