# ════════════════════════════════════════════════════════════════════════════
# ResolveAI — Environment Variables
# Copy this file to .env and fill in your own values.
# .env is gitignored and must NEVER be committed.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=pretty                # pretty (coloured console) | json (production)

# ── LLM provider ─────────────────────────────────────────────────────────────
# Switch between local (free) and cloud with one line.
LLM_PROVIDER=ollama              # "ollama" (free, local) | "anthropic" (paid)

# Ollama — free, runs on your machine. https://ollama.com
# After installing Ollama: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic — uncomment when you have an API key
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# ── Agent behaviour ───────────────────────────────────────────────────────────
AGENT_MAX_TOKENS=1024
AGENT_TEMPERATURE=0.1
AGENT_MEMORY_WINDOW=20           # turns kept in the sliding-window buffer
AGENT_PROMPT_VERSION=v1          # which system_prompt_v{N}.md to load
AGENT_RETRIEVAL_TOP_K=5          # KB results returned per search
AGENT_LOW_CONFIDENCE_THRESHOLD=0.4  # below this similarity score → escalate

# ── Vector store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=insurance_kb

# ── Mock CRM (runs locally via Docker — no real credentials needed) ───────────
MOCK_CRM_URL=http://localhost:8002
MOCK_CRM_API_KEY=mock-crm-secret-key

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=resolveai
POSTGRES_USER=resolveai
POSTGRES_PASSWORD=changeme-in-prod
DATABASE_URL=postgresql://resolveai:changeme-in-prod@localhost:5432/resolveai

# ── Week 2+ integrations (leave blank for now) ────────────────────────────────
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_ESCALATION_CHANNEL=#support-escalations
GOOGLE_CREDENTIALS_FILE=credentials/google_credentials.json
GOOGLE_CALENDAR_ID=primary

# ── Week 3+ voice (leave blank for now) ──────────────────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
PUBLIC_BASE_URL=http://localhost:8000